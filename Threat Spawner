---====== SOUND HELPER ======---

local function GitAud(url, filename)
	local file = filename .. ".mp3"

	if not isfile(file) then
		writefile(file, game:HttpGet(url))
	end

	if not isfile(file) then
		warn("Sound failed to download")
		return nil
	end

	local success, asset = pcall(function()
		return (getcustomasset or getsynasset)(file)
	end)

	if not success then
		warn("getcustomasset failed")
		return nil
	end

	return asset
end

---====== On Spawn ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	game.Lighting.MainColorCorrection.TintColor = Color3.fromRGB(244, 0, 255)

	local id = GitAud(
		"https://github.com/reboundplayz/doors-fear-mode-images/raw/refs/heads/main/ScreenRecording_06-24-2025%2017-33-48_1.mp3",
		"threat_spawn"
	)

	if id then
		local sound = Instance.new("Sound")
		sound.SoundId = id
		sound.Volume = 10
		sound.Parent = workspace
		sound:Play()
	end
end)

---====== On Start Moving ======---

entity.Debug.OnEntityStartMoving = function()
	print("Entity has started moving")

	local id = GitAud(
		"https://github.com/reboundplayz/doors-fear-mode-images/raw/refs/heads/main/ScreenRecording_06-24-2025%2017-40-08_1.mp3?raw=true",
		"threat_movesound"
	)

	if not id then return end

	-- find entity model safely
	local model
	repeat
		for _, v in pairs(workspace:GetChildren()) do
			if v:IsA("Model") and v:FindFirstChildWhichIsA("BasePart") then
				model = v
			end
		end
		task.wait()
	until model

	-- ensure PrimaryPart
	if not model.PrimaryPart then
		local base = model:FindFirstChildWhichIsA("BasePart")
		if base then
			model.PrimaryPart = base
		end
	end

	local part = model.PrimaryPart
	if not part then
		warn("No valid part found")
		return
	end

	local sound = Instance.new("Sound")
	sound.Name = "EntitySound"
	sound.SoundId = id
	sound.Parent = part

	sound.Volume = 5
	sound.Looped = true
	sound.RollOffMode = Enum.RollOffMode.Linear
	sound.RollOffMaxDistance = 1000
	sound.RollOffMinDistance = 10

	sound:Play()
end

---====== Despawn Cleanup ======---

entity.Debug.OnEntityDespawned = function()
	print("Entity has despawned")

	local sound = workspace:FindFirstChild("EntitySound", true)
	if sound then
		sound:Destroy()
	end

	game.Lighting.MainColorCorrection.TintColor = Color3.fromRGB(255, 255, 255)
end

