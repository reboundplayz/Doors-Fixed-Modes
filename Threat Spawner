-- This makes EACH color fade in, then fade out into the next one smoothly

task.spawn(function()
	local rainbow = {
		Color3.fromRGB(255,170,185), -- soft pink
		Color3.fromRGB(255,205,150), -- peach
		Color3.fromRGB(255,240,170), -- soft yellow
		Color3.fromRGB(185,255,185), -- mint
		Color3.fromRGB(170,245,255), -- cyan
		Color3.fromRGB(185,185,255), -- pastel blue
		Color3.fromRGB(255,180,255)  -- lavender pink
	}

	-- start from saved/original room color feel
	for _, color in ipairs(rainbow) do
		-- fade INTO this color
		TweenRoomColor(color, 0.22)
		task.wait(0.22)

		-- hold briefly like the video pulse
		task.wait(0.06)

		-- fade slightly darker version before next color
		local dim = Color3.new(
			color.R * 0.72,
			color.G * 0.72,
			color.B * 0.72
		)

		TweenRoomColor(dim, 0.14)
		task.wait(0.14)
	end

	-- smooth merge into Threat purple
	TweenRoomColor(Color3.fromRGB(244,0,255), 0.55)
end)

end)

---====== On Start Moving ======---

entity.Debug.OnEntityStartMoving = function()
	print("Entity has started moving")

	local id = GitAud(
		"https://github.com/reboundplayz/doors-fear-mode-images/raw/refs/heads/main/ScreenRecording_06-24-2025%2017-40-08_1.mp3?raw=true",
		"threat_movesound"
	)

	if not id then return end

	-- find entity model safely
	local model
	repeat
		for _, v in pairs(workspace:GetChildren()) do
			if v:IsA("Model") and v:FindFirstChildWhichIsA("BasePart") then
				model = v
			end
		end
		task.wait()
	until model

	-- ensure PrimaryPart
	if not model.PrimaryPart then
		local base = model:FindFirstChildWhichIsA("BasePart")
		if base then
			model.PrimaryPart = base
		end
	end

	local part = model.PrimaryPart
	if not part then
		warn("No valid part found")
		return
	end

	local sound = Instance.new("Sound")
	sound.Name = "EntitySound"
	sound.SoundId = id
	sound.Parent = part

	sound.Volume = 5
	sound.Looped = true
	sound.RollOffMode = Enum.RollOffMode.Linear
	sound.RollOffMaxDistance = 1000
	sound.RollOffMinDistance = 10

	sound:Play()
end

