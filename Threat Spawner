local TweenService = game:GetService("TweenService")

--====== ROOM COLOR SYSTEM ======--

local savedColors = {}
local activeRoom

local function GetCurrentRoom()
	local num = game.ReplicatedStorage.GameData.LatestRoom.Value
	return workspace.CurrentRooms:FindFirstChild(tostring(num))
end

local function SaveRoom(room)
	savedColors = {}
	if not room then return end

	for _,v in pairs(room:GetDescendants()) do
		if v:IsA("BasePart") then
			savedColors[v] = v.Color
		elseif v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
			savedColors[v] = v.Color
		end
	end
end

local function SetRoomColor(color)
	if not activeRoom then return end

	for _,v in pairs(activeRoom:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Color = color
		elseif v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
			v.Color = color
		end
	end
end

local function TweenRoomColor(color,time)
	if not activeRoom then return end

	for _,v in pairs(activeRoom:GetDescendants()) do
		if v:IsA("BasePart") then
			TweenService:Create(v,TweenInfo.new(time),{Color=color}):Play()
		elseif v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
			TweenService:Create(v,TweenInfo.new(time),{Color=color}):Play()
		end
	end
end

local function RestoreRoom(time)
	for obj,col in pairs(savedColors) do
		if obj and obj.Parent then
			pcall(function()
				TweenService:Create(obj,TweenInfo.new(time),{Color=col}):Play()
			end)
		end
	end
end

