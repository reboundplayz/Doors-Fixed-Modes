--====== FEAR BAR SYSTEM (BOTTOM RIGHT, MATCHED STYLE) ======--

local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "FearBarGUI"
gui.Parent = player:WaitForChild("PlayerGui")

-- Container (bottom right)
local bg = Instance.new("Frame")
bg.Size = UDim2.new(0.22, 0, 0.035, 0)
bg.Position = UDim2.new(0.75, 0, 0.92, 0) -- bottom right
bg.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
bg.BorderSizePixel = 0
bg.Parent = gui

-- Rounded corners
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = bg

-- Outline (light beige like image)
local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 230, 180)
stroke.Thickness = 2
stroke.Parent = bg

-- Inner padding
local padding = Instance.new("UIPadding")
padding.PaddingLeft = UDim.new(0, 4)
padding.PaddingRight = UDim.new(0, 4)
padding.PaddingTop = UDim.new(0, 4)
padding.PaddingBottom = UDim.new(0, 4)
padding.Parent = bg

-- Fill bar (red)
local fill = Instance.new("Frame")
fill.Size = UDim2.new(0, 0, 1, 0)
fill.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
fill.BorderSizePixel = 0
fill.Parent = bg

local fillCorner = Instance.new("UICorner")
fillCorner.CornerRadius = UDim.new(0, 6)
fillCorner.Parent = fill

-- Fear values
local fear = 0
local maxFear = 100

local function UpdateFear(amount)
    fear = math.clamp(fear + amount, 0, maxFear)

    fill:TweenSize(
        UDim2.new(fear / maxFear, 0, 1, 0),
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Quad,
        0.25,
        true
    )
end

local caption = game.Players.LocalPlayer:WaitForChild("PlayerGui").MainUI.MainFrame.Caption
caption.TextColor3 = Color3.fromRGB(255, 255, 255)
require(game.Players.LocalPlayer.PlayerGui.MainUI.Initiator.Main_Game).caption("Fear Mode Multiplayer Executed!",true)
game.ReplicatedStorage.GameData.LatestRoom.Changed:Wait()
