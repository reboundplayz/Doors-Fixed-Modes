caption.TextColor3 = Color3.fromRGB(255, 255, 255)
require(game.Players.LocalPlayer.PlayerGui.MainUI.Initiator.Main_Game).caption("Fear Mode Initiated, Made by Oof, Fixed entities by reboundplayz and voorpr0",true)

