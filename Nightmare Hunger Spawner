local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local triggered = false

-- GitHub sound loader (requested getcustomasset version)
local function GitAud(soundgit, filename)
    local FileName = filename
    writefile(FileName..".mp3", game:HttpGet(soundgit))
    return (getcustomasset or getsynasset)(FileName..".mp3")
end

local function PlayKickSound()
    local sound = Instance.new("Sound")
    sound.Parent = workspace
    sound.Volume = 5
    sound.Looped = true

    -- GitHub audio
    local success, asset = pcall(function()
        return GitAud(
            "https://github.com/reboundplayz/doors-fear-mode-images/raw/refs/heads/main/ScreenRecording_07-04-2025%2016-09-19_1.mp3",
            "hunger_kick"
        )
    end)

    if success then
        sound.SoundId = asset
    else
        sound.SoundId = "rbxassetid://933230732" -- fallback
    end

    sound:Play()
end

RunService.Heartbeat:Connect(function()
    if triggered then return end
    if not depthsTer or not depthsTer.Parent then return end

    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local hrp = char.HumanoidRootPart

    for _, v in pairs(depthsTer:GetDescendants()) do
        if v:IsA("BasePart") then
            if (hrp.Position - v.Position).Magnitude < 6 then
                triggered = true

                PlayKickSound()
                task.wait(0.2)

                player:Kick("You got too close to Nightmare Hunger...")
                return
            end
        end
    end
end)

