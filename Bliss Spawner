--// Function to recolor ONLY current room
local changedParts = {}

local function ChangeRoomColor(room, color)
	if not room then return end
	
	for _, obj in pairs(room:GetDescendants()) do
		if obj:IsA("BasePart") then
			changedParts[obj] = obj.Color -- save original color
			obj.Color = color
		elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
			obj.Color = color
		end
	end
end

