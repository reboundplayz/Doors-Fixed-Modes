---====== Independent Stuck & Clone Watchdog ======---
task.spawn(function()
    local lastPos = Vector3.new(0,0,0)
    local lastMoveTick = tick()
    
    while task.wait(0.1) do
        local model = workspace:FindFirstChild("SY3T4M")
        
        for _, v in pairs(workspace:GetChildren()) do
            if v.Name == "SY3T4M" and v ~= model then
                v:Destroy()
            end
        end
        
        if model and model.PrimaryPart then
            local currentPos = model.PrimaryPart.Position
            if (currentPos - lastPos).Magnitude > 0.3 then
                lastPos = currentPos
                lastMoveTick = tick()
            else
                if (tick() - lastMoveTick) > 2 then
                    model:Destroy()
                    task.wait(0.2)
                    entity:Run(true)
                    lastMoveTick = tick()
                end
            end
            
            for _, p in pairs(model:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false p.Massless = true end
            end
        end
    end
end)

---====== The "Permanent Smash" Function ======---
local function explodeHidingSpot(model)
    if not model or brokenSpots[model] then return end
    brokenSpots[model] = true 

   local breakSound = Instance.new("Sound")
    breakSound.SoundId = "rbxassetid://9125584819"
    breakSound.Volume = 5

    -- 🔥 Random pitch
    breakSound.PlaybackSpeed = math.random(60,140) / 100 -- 0.8 to 1.2 range

    breakSound.Parent = workspace
    breakSound:Play()
    game:GetService("Debris"):AddItem(breakSound, 5)

    local center = model:GetModelCFrame().Position

    -- Create a folder for the debris so it's organized
    local debrisFolder = workspace:FindFirstChild("SY3T4M_Debris") or Instance.new("Folder", workspace)
    debrisFolder.Name = "SY3T4M_Debris"

    for _, obj in pairs(model:GetDescendants()) do
        -- Destroy prompts and welds
        if obj:IsA("Weld") or obj:IsA("ManualWeld") or obj:IsA("WeldConstraint") or obj:IsA("ProximityPrompt") or obj.Name:find("HidePrompt") then
            pcall(function() obj:Destroy() end)
        
        -- Move parts to Workspace/DebrisFolder so the room-cleaner can't delete them
        elseif obj:IsA("BasePart") then
            obj.Parent = debrisFolder
            obj.Anchored = false
            obj.CanCollide = true
            
            -- Random slight rotation for "crunchy" look
            obj.CFrame = obj.CFrame * CFrame.Angles(math.rad(math.random(-10,10)), math.rad(math.random(-10,10)), 0)
            
            pcall(function() obj:SetNetworkOwner(nil) end)
            
            -- High velocity explosion
            local dir = (obj.Position - center).Unit
            obj.AssemblyLinearVelocity = (dir + Vector3.new(0, 1.2, 0)).Unit * 250
        end
    end
    
    -- Finally, remove the empty model shell
    model:Destroy()
end

---====== Smooth Movement ======---
local function smoothMove(targetPos, travelSpeed, isCloset, myID)
    local entityModel = workspace:FindFirstChild("SY3T4M")
    if not entityModel or not entityModel.PrimaryPart then return end
    
    local root = entityModel.PrimaryPart
    local finalTarget = targetPos

    if isCloset then
        local direction = (targetPos - root.Position).Unit
        finalTarget = targetPos - (direction * 8.5)
    end

    local distance = (root.Position - finalTarget).Magnitude
    if distance < 1.5 then return end 

    local duration = distance / travelSpeed
    local startTick = tick()
    local done = false
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if myID ~= currentThreadID or not entityModel.Parent then 
            done = true connection:Disconnect() return 
        end

        local elapsed = tick() - startTick
        local alpha = math.min(elapsed / duration, 1)
        local easedAlpha = 1 - math.pow(1 - alpha, 3)
        local currentPos = root.Position:Lerp(finalTarget, easedAlpha)
        
        if not isCloset and (root.Position - finalTarget).Magnitude < 4 then alpha = 1 end

        if (targetPos - currentPos).Magnitude > 1 then
            entityModel:PivotTo(CFrame.new(currentPos, targetPos))
        else
            entityModel:PivotTo(CFrame.new(currentPos))
        end
        
        if alpha >= 1 then done = true connection:Disconnect() end
    end)
    
    repeat task.wait() until done or not entityModel.Parent
end

local function processRoom(room)
    currentThreadID = currentThreadID + 1
    local myID = currentThreadID

    local targets = {}
    for _, obj in pairs(room:GetDescendants()) do
        if (obj.Name == "HidePrompt" or obj:IsA("ProximityPrompt")) and obj.Parent:IsA("Model") then
            if not brokenSpots[obj.Parent] then table.insert(targets, obj.Parent) end
        end
    end

    for _, closet in pairs(targets) do
        if myID ~= currentThreadID then return end
        smoothMove(closet:GetModelCFrame().Position, 230, true, myID)
        task.wait(0.3) 
        explodeHidingSpot(closet)
    end

    if myID == currentThreadID then
        local nextNode = room:FindFirstChild("Exit") or room:FindFirstChild("Entry")
        if nextNode then smoothMove(nextNode.Position, 260, false, myID) end
    end
end

---====== Callbacks ======---
entity:SetCallback("OnEnterRoom", function(room)
    task.spawn(function() processRoom(room) end)
end)

entity:SetCallback("OnSpawned", function()
    local latestRoomNumber = game.ReplicatedStorage.GameData.LatestRoom.Value
    local currentRoom = workspace.CurrentRooms:FindFirstChild(tostring(latestRoomNumber))
    
    if currentRoom then
        task.spawn(function() processRoom(currentRoom) end)
    end
end)

entity:Run(true)
